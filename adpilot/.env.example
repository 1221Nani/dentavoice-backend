# AdPilot AI — Environment Variables
# Copy this to .env and fill in your actual keys

# ─── Meta Ads ───────────────────────────────────────────
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# ─── Google Ads ─────────────────────────────────────────
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# ─── AI Services ────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
RUNWAY_API_KEY=

# ─── App ────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./adpilot.db
SECRET_KEY=change-me-to-a-long-random-string-in-production
